# Firebase Configuration
# These NEXT_PUBLIC_* values are baked into the client bundle during `next build`.
# For Docker deployments, provide them during image build and keep the same values
# available at runtime for clarity and operational consistency.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin Configuration (runtime only, server-side)
# Required for protected AI routes that verify Firebase ID tokens.
# Use ONE of the two options below.

# Option A: separate service-account fields (recommended for local development)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B: full service-account JSON encoded as base64
# FIREBASE_ADMIN_CREDENTIALS_BASE64=base64_encoded_service_account_json_here

# Anthropic AI Configuration (runtime only, server-side)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Registrations
# Set to 'false' to disable new user registrations and Google sign-in.
# This is the supported fallback for self-hosted installs that do not configure
# a public hostname + Firebase authorized domain for Google OAuth.
NEXT_PUBLIC_REGISTRATIONS_ENABLED=true
